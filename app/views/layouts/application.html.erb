<!DOCTYPE html>
<html>
  <head>
    <title>MiniSocial</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

<body>

  <nav class="navbar">
    <div class="nav-left">
      <%= link_to "MiniSocial", root_path, class: "logo" %>
    </div>

    <div class="nav-right">
      <% if user_signed_in? %>
        <%= link_to "Profile", profile_path(current_user), class: "nav-link" %>
        <%= button_to "Logout", destroy_user_session_path, method: :delete, class: "btn-logout" %>
      <% else %>
        <%= link_to "Login", new_user_session_path, class: "nav-link" %>
        <%= link_to "Register", new_user_registration_path, class: "nav-link register" %>
      <% end %>
    </div>
  </nav>

  <div class="container">
    <%= yield %>
  </div>

  <footer class="footer">
    <p>© 2026 Watch Store. All rights reserved.</p>
  </footer>

</body>
</html>
