<div class="feed">

  <div class="new-post">
    <h2>Create Post</h2>

    <%= form_with model: @post do |f| %>
      <%= f.text_area :content, placeholder: "What's on your mind?", class: "post-input" %>
      <%= f.submit "Post", class: "btn-primary" %>
    <% end %>
  </div>

<% @posts.each do |post| %>

  <div class="post-card">

    <div class="post-header">
      <strong><%= post.user.email %></strong>
    </div>

    <div class="post-content">
      <%= post.content %>
    </div>

    <!-- ✅ REACTIONS HERE -->

    <div class="reaction-buttons">

      <%= button_to "👍 Like",
          post_reactions_path(post, kind: :like),
          method: :post,
          class: "btn-like" %>

      <%= button_to "👎 Dislike",
          post_reactions_path(post, kind: :dislike),
          method: :post,
          class: "btn-dislike" %>

      <span class="counts">
        👍 <%= post.reactions.like.count %>
        👎 <%= post.reactions.dislike.count %>
      </span>

    </div>

  </div>

<% end %>
