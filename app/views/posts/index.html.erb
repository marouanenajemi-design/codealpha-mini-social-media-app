<div class="feed">

  <div class="new-post">
    <h2>Create Post</h2>

    <%= form_with model: @post do |f| %>
      <%= f.text_area :content, placeholder: "What's on your mind?", class: "post-input" %>
      <%= f.submit "Post", class: "btn-primary" %>
    <% end %>
  </div>

  <% @posts.each do |post| %>
    <div class="post-card">

      <div class="post-header">
        <strong><%= post.user.email %></strong>
      </div>

      <p class="post-content"><%= post.content %></p>

      <div class="comments">
        <% post.comments.each do |comment| %>
          <p><strong><%= comment.user.email %></strong> <%= comment.content %></p>
        <% end %>
      </div>

      <%= form_with model: [post, Comment.new], class: "comment-form" do |f| %>
        <%= f.text_field :content, placeholder: "Write a comment...", class: "comment-input" %>
      <% end %>

    </div>
  <% end %>

</div>
